# AURUM — Variables de Entorno Requeridas
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ─── MetaTrader 5 ─────────────────────────────────────────────────────────────
MT5_LOGIN=123456789          # Número de cuenta MT5 (verificación de seguridad al arrancar)

# ─── PostgreSQL (Google Cloud Platform) ───────────────────────────────────────
DB_HOST=<ip-gcp-instance>
DB_PORT=5432
DB_NAME=aurum_db
DB_USER=aurum_user
DB_PASS=<password>

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<token-del-bot-botfather>
TELEGRAM_CHAT_ID=<tu-chat-id-personal>

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=<api-key-de-google-ai-studio>

# ─── NLP Config (opcional) ────────────────────────────────────────────────────
NLP_CACHE_TTL_MIN=30         # Tiempo de vida del caché NLP en minutos (default: 30)
